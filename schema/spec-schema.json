{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specgate.dev/spec-schema.json",
  "title": "SpecGate operation spec",
  "description": "Schema for a SpecGate operation spec file (.spec.yaml).",
  "type": "object",
  "required": ["name", "kind", "inputs"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Operation name. This is the grouping key across annotations."
    },
    "kind": {
      "type": "string",
      "enum": ["Pure", "StateMachine", "Sequence", "ErrorMap", "Structural"],
      "description": "Determines extraction strategy and which roles are valid."
    },
    "inputs": {
      "type": "array",
      "description": "Named, typed parameters for the operation.",
      "items": { "$ref": "#/$defs/typedField" }
    },
    "environments": {
      "type": "array",
      "description": "Ambient state the operation reads.",
      "items": { "$ref": "#/$defs/typedField" }
    },
    "dependencies": {
      "type": "array",
      "description": "External services or non-deterministic calls.",
      "items": {
        "type": "object",
        "required": ["name", "type", "dep"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Dependency name matching the annotation."
          },
          "type": {
            "type": "string",
            "description": "Spec type of the dependency."
          },
          "dep": {
            "type": "string",
            "description": "Dependency category (e.g., external_service, clock, random)."
          }
        }
      }
    },
    "outcome": {
      "type": "object",
      "description": "Outcome variants for the operation.",
      "required": ["oneof"],
      "additionalProperties": false,
      "properties": {
        "oneof": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of named outcome variants."
        }
      }
    },
    "outputs": {
      "type": "object",
      "description": "Per-outcome output fields, keyed by 'when <Variant>'.",
      "patternProperties": {
        "^when .+$": {
          "type": "array",
          "items": { "$ref": "#/$defs/typedField" }
        }
      },
      "additionalProperties": false
    },
    "checkpoints": {
      "type": "array",
      "description": "Observable intermediate values.",
      "items": { "$ref": "#/$defs/typedField" }
    },
    "states": {
      "type": "array",
      "description": "State snapshots (StateMachine kind only).",
      "items": { "$ref": "#/$defs/typedField" }
    },
    "cases": {
      "type": "array",
      "description": "Concrete test cases.",
      "items": { "$ref": "#/$defs/testCase" }
    }
  },
  "$defs": {
    "typedField": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Field name."
        },
        "type": {
          "type": "string",
          "description": "Spec type (e.g., str, int, bool, Option[str], List[int], User)."
        }
      }
    },
    "testCase": {
      "type": "object",
      "required": ["name", "inputs", "outcome"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable case description."
        },
        "inputs": {
          "type": "object",
          "description": "Values for all inputs, keyed by input name.",
          "additionalProperties": true
        },
        "environments": {
          "type": "object",
          "description": "Values for ambient state, keyed by environment name.",
          "additionalProperties": true
        },
        "dependency_responses": {
          "type": "object",
          "description": "Controlled responses from dependencies, keyed by dependency name.",
          "additionalProperties": true
        },
        "outcome": {
          "type": "string",
          "description": "Which outcome variant is expected."
        },
        "outputs": {
          "type": "object",
          "description": "Expected output values for this outcome.",
          "additionalProperties": true
        },
        "checkpoints": {
          "type": "array",
          "description": "Expected intermediate values.",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
