{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specgate.dev/extraction-schema.json",
  "title": "SpecGate extraction result",
  "description": "Language-agnostic intermediate format emitted by language-specific front-ends. Consumed by specgate-core for validation and spec generation.",
  "type": "object",
  "required": ["source_language", "symbols"],
  "additionalProperties": false,
  "properties": {
    "source_language": {
      "type": "string",
      "description": "The source language of the extracted code (e.g., 'csharp', 'rust')."
    },
    "project": {
      "type": "string",
      "description": "Project or crate name the extraction was run on."
    },
    "symbols": {
      "type": "array",
      "description": "All symbols that carry at least one SpecGate annotation.",
      "items": { "$ref": "#/$defs/annotatedSymbol" }
    },
    "types": {
      "type": "array",
      "description": "Type information for all types referenced by annotated symbols. Used for constructability analysis.",
      "items": { "$ref": "#/$defs/typeInfo" }
    }
  },
  "$defs": {
    "annotatedSymbol": {
      "type": "object",
      "required": ["name", "symbol_kind", "annotations"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Symbol name (method name, property name, constructor, etc.)."
        },
        "symbol_kind": {
          "type": "string",
          "enum": ["method", "property", "field", "constructor", "parameter"],
          "description": "What kind of code symbol this is."
        },
        "declaring_type": {
          "type": "string",
          "description": "Fully qualified name of the type that declares this symbol."
        },
        "return_type": {
          "type": "string",
          "description": "Return type of the symbol (for methods/properties). Language-native syntax."
        },
        "type": {
          "type": "string",
          "description": "Type of the symbol (for fields, parameters, properties). Language-native syntax."
        },
        "parameters": {
          "type": "array",
          "description": "Parameters (for methods and constructors).",
          "items": { "$ref": "#/$defs/parameterInfo" }
        },
        "accessibility": {
          "type": "string",
          "enum": ["public", "internal", "protected", "private"],
          "description": "Visibility of the symbol."
        },
        "is_static": {
          "type": "boolean",
          "description": "Whether the symbol is static."
        },
        "is_async": {
          "type": "boolean",
          "description": "Whether the method is async."
        },
        "location": {
          "$ref": "#/$defs/sourceLocation",
          "description": "Source file location of the symbol."
        },
        "annotations": {
          "type": "array",
          "description": "SpecGate annotations on this symbol.",
          "items": { "$ref": "#/$defs/annotation" }
        }
      }
    },
    "annotation": {
      "type": "object",
      "required": ["attribute"],
      "additionalProperties": false,
      "properties": {
        "attribute": {
          "type": "string",
          "enum": [
            "SpecOperation",
            "SpecInput",
            "SpecCheckpoint",
            "SpecState",
            "SpecEnvironment",
            "SpecDependency",
            "SpecGenerator",
            "SpecContext"
          ],
          "description": "The SpecGate attribute name."
        },
        "args": {
          "type": "object",
          "description": "Attribute arguments as key-value pairs.",
          "additionalProperties": true,
          "properties": {
            "name": {
              "type": "string",
              "description": "The operation name (positional arg on most attributes)."
            },
            "kind": {
              "type": "string",
              "enum": ["Pure", "StateMachine", "Sequence", "ErrorMap", "Structural"],
              "description": "SpecKind (only on SpecOperation)."
            },
            "dep": {
              "type": "string",
              "description": "Dependency category (only on SpecDependency)."
            },
            "type_name": {
              "type": "string",
              "description": "Target type name (only on SpecGenerator)."
            }
          }
        }
      }
    },
    "typeInfo": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Fully qualified type name."
        },
        "is_abstract": {
          "type": "boolean",
          "description": "Whether the type is abstract or an interface."
        },
        "is_generic": {
          "type": "boolean",
          "description": "Whether the type has generic parameters."
        },
        "generic_parameters": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names of generic type parameters."
        },
        "accessibility": {
          "type": "string",
          "enum": ["public", "internal", "protected", "private"],
          "description": "Visibility of the type."
        },
        "constructors": {
          "type": "array",
          "description": "Public constructors of the type.",
          "items": { "$ref": "#/$defs/constructorInfo" }
        },
        "has_spec_generator": {
          "type": "boolean",
          "description": "Whether a [SpecGenerator] exists for this type anywhere in the extraction."
        },
        "base_type": {
          "type": "string",
          "description": "Fully qualified name of the base type, if any."
        }
      }
    },
    "constructorInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accessibility": {
          "type": "string",
          "enum": ["public", "internal", "protected", "private"],
          "description": "Visibility of the constructor."
        },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/parameterInfo" }
        }
      }
    },
    "parameterInfo": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Parameter name."
        },
        "type": {
          "type": "string",
          "description": "Parameter type in language-native syntax."
        },
        "is_optional": {
          "type": "boolean",
          "description": "Whether the parameter has a default value."
        },
        "default_value": {
          "type": "string",
          "description": "Default value as a string, if optional."
        }
      }
    },
    "sourceLocation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Relative file path."
        },
        "line": {
          "type": "integer",
          "description": "Line number (1-based)."
        },
        "column": {
          "type": "integer",
          "description": "Column number (1-based)."
        }
      }
    }
  }
}
