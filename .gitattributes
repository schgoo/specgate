# Auto-detect text files and normalize line endings to LF.
* text=auto eol=lf

# Rust source
*.rs text eol=lf
*.toml text eol=lf

# Scripts
*.sh text eol=lf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Documentation
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.svg text eol=lf
