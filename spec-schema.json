{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpecGate Component Spec",
  "description": "Schema for SpecGate .spec.yaml files (v0.4.0). Specs declare types, operations (each with their own inputs/outputs), and test cases that exercise them.",
  "type": "object",
  "required": ["name", "spec_version", "operations", "cases"],
  "properties": {
    "spec_version": {
      "type": "string",
      "description": "Schema version. Current version is '0.4.0'.",
      "const": "0.4.0"
    },
    "name": {
      "type": "string",
      "description": "Dotted component name, e.g. specgate.harness"
    },
    "binding": {
      "description": "Binding(s) for this spec. A string for a single binding, or a list for multiple implementations.",
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "target": {
      "type": "string",
      "description": "Which target in the binding to use. Defaults to the first target if omitted."
    },
    "depends_on": {
      "type": "array",
      "description": "List of spec names this spec depends on.",
      "items": { "type": "string" }
    },
    "types": {
      "type": "object",
      "description": "Named type definitions shared across operations. Each key is a type name, value is a type definition.",
      "additionalProperties": { "$ref": "#/definitions/namedType" }
    },
    "operations": {
      "type": "object",
      "description": "Named operations, each declaring its own inputs, outputs, and outcome.",
      "additionalProperties": { "$ref": "#/definitions/operation" }
    },
    "cases": {
      "type": "array",
      "description": "Test cases.",
      "items": { "$ref": "#/definitions/testCase" }
    }
  },
  "definitions": {
    "namedType": {
      "description": "A named type definition. Either a struct (fields) or an enum (oneof).",
      "type": "object",
      "properties": {
        "fields": {
          "type": "object",
          "description": "Struct type: keys are field names, values are type references (string for scalars/named types, object for inline complex types)."
        },
        "oneof": {
          "type": "object",
          "description": "Enum type: keys are variant names, values are objects with the variant's fields (empty object for unit variants)."
        }
      },
      "oneOf": [
        { "required": ["fields"] },
        { "required": ["oneof"] }
      ]
    },
    "typeReference": {
      "description": "A type reference: either a scalar type name (string), a named type reference (string), or an inline complex type definition (object).",
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/definitions/typeDefinition" }
      ]
    },
    "typeDefinition": {
      "description": "Inline type definition for complex/collection types.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Type kind: list, map, set, optional, or a scalar (string, i32, i64, f64, bool).",
          "enum": ["string", "i32", "i64", "f64", "bool", "list", "map", "set", "optional"]
        },
        "items": {
          "description": "Element type for list, set, and optional. A string (type name) or inline type definition.",
          "$ref": "#/definitions/typeReference"
        },
        "fields": {
          "type": "object",
          "description": "For inline struct definitions. Keys are field names, values are type references."
        },
        "keys": {
          "description": "Key type for map types.",
          "$ref": "#/definitions/typeReference"
        },
        "values": {
          "description": "Value type for map types.",
          "$ref": "#/definitions/typeReference"
        }
      },
      "required": ["type"]
    },
    "operation": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "description": "Operation kind. 'setup' creates state objects. 'command' runs a shell command. Default is a regular annotated operation.",
          "enum": ["setup", "command"]
        },
        "async": {
          "type": "boolean",
          "description": "Whether this operation is async.",
          "default": false
        },
        "desc": {
          "type": "string",
          "description": "Human-readable description of this operation."
        },
        "inputs": {
          "type": "object",
          "description": "Named input declarations. Values are type references (string for scalar, object for complex types).",
          "additionalProperties": { "$ref": "#/definitions/typeReference" }
        },
        "outputs": {
          "type": "array",
          "description": "Observable outputs. Each item is a bare event name (string) or an object mapping event name to type reference.",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "object" }
            ]
          }
        }
      }
    },
    "testCase": {
      "oneOf": [
        { "$ref": "#/definitions/narrativeCase" },
        { "$ref": "#/definitions/runnableCase" },
        { "$ref": "#/definitions/propertyCase" }
      ]
    },
    "narrativeCase": {
      "type": "object",
      "required": ["name", "kind", "desc"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "kind": {
          "type": "string",
          "const": "narrative"
        },
        "desc": {
          "type": "string"
        },
        "verify": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "propertyCase": {
      "type": "object",
      "required": ["name", "kind", "runs", "generators", "calls", "expected"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "kind": {
          "type": "string",
          "const": "property"
        },
        "desc": {
          "type": "string"
        },
        "runs": {
          "type": "integer",
          "description": "Number of random iterations to run.",
          "minimum": 1
        },
        "generators": {
          "type": "object",
          "description": "Named generators. Values are generator expressions (e.g. 'i32[-1000, 1000]', 'bool', 'string[1, 50]').",
          "additionalProperties": { "type": "string" }
        },
        "calls": {
          "type": "object",
          "description": "Named calls. Each maps to an operation invocation with inputs referencing generators via {name}.",
          "additionalProperties": {
            "type": "object",
            "required": ["operation"],
            "properties": {
              "operation": { "type": "string" },
              "inputs": { "type": "object" }
            }
          }
        },
        "expected": {
          "type": "array",
          "description": "List of $assert expressions comparing call results and generator values.",
          "items": {
            "type": "object",
            "properties": {
              "$assert": { "type": "string" }
            },
            "required": ["$assert"]
          }
        }
      }
    },
    "runnableCase": {
      "type": "object",
      "required": ["name", "desc"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "desc": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "description": "Omit for standard runnable cases.",
          "not": {
            "enum": ["narrative", "property"]
          }
        },
        "target": {
          "type": "string",
          "description": "Override the spec-level target for this case."
        },
        "level": {
          "type": "string",
          "description": "Normative strength: must=error, should=warn, may=skip.",
          "enum": ["must", "should", "may"],
          "default": "must"
        },
        "source": {
          "type": "object",
          "description": "Provenance metadata linking this case to source specification assertions.",
          "properties": {
            "assertion_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "spec": { "type": "string" },
            "section": { "type": "string" }
          }
        },
        "operation": {
          "type": "string",
          "description": "Operation to invoke (must match a key in the operations block)."
        },
        "setup": {
          "description": "Setup operation name (string) or map of named setups with inputs.",
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        },
        "inputs": {
          "type": "object",
          "description": "Input values for this case."
        },
        "expected": {
          "description": "Expected trace assertions or structured outcome.",
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "object" }
            },
            {
              "type": "object"
            }
          ]
        },
        "steps": {
          "type": "array",
          "description": "Ordered step sequence for multi-step cases.",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/testStep" },
              { "$ref": "#/definitions/concurrentBlock" }
            ]
          },
          "minItems": 1
        }
      }
    },
    "concurrentBlock": {
      "type": "object",
      "required": ["concurrent"],
      "properties": {
        "concurrent": {
          "type": "array",
          "description": "Operations that run in parallel.",
          "items": { "$ref": "#/definitions/testStep" },
          "minItems": 1
        }
      }
    },
    "testStep": {
      "type": "object",
      "required": ["operation"],
      "properties": {
        "operation": { "type": "string" },
        "inputs": { "type": "object" },
        "expected": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  }
}
