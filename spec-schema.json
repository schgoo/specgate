{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpecGate Component Spec",
  "description": "Schema for SpecGate .spec.yaml files. Specs declare test cases with expected trace assertions. The harness resolves the binding, runs annotated code, and compares actual traces against expected.",
  "type": "object",
  "required": ["name", "cases"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Dotted component name, e.g. fixture.stateless_add"
    },
    "binding": {
      "description": "Path to the binding YAML file (relative to this spec file).",
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "description": "List of spec names this spec depends on.",
      "items": { "type": "string" }
    },
    "inputs": {
      "type": "object",
      "description": "Named input declarations for the component."
    },
    "types": {
      "type": "object",
      "description": "Named type definitions."
    },
    "outcome": {
      "description": "Outcome variants for the component."
    },
    "outputs": {
      "type": "object",
      "description": "Output declarations keyed by 'when <Outcome>'."
    },
    "state": {
      "type": "object",
      "description": "State variables for state machine specs."
    },
    "init": {
      "type": "object",
      "description": "Initial state values."
    },
    "operations": {
      "type": "object",
      "description": "Named operations for state machine specs."
    },
    "invariants": {
      "type": "object",
      "description": "Named invariants."
    },
    "cases": {
      "type": "array",
      "description": "Test cases.",
      "items": { "$ref": "#/definitions/testCase" }
    }
  },
  "definitions": {
    "testCase": {
      "type": "object",
      "required": ["name", "desc"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique snake_case test name.",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "desc": {
          "type": "string",
          "description": "Human-readable description."
        },
        "operation": {
          "type": "string",
          "description": "Operation to invoke."
        },
        "setup": {
          "description": "Setup function name (string) or map of named setups.",
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        },
        "inputs": {
          "type": "object",
          "description": "Input values for this case. Values can be literals or file references: { file: 'path' }."
        },
        "expected": {
          "type": "array",
          "description": "List of expected trace assertions. Each item is a map with one key: either a field name (value assertion) or 'run' (operation assertion). Matched as a subsequence of the actual trace stream.",
          "items": {
            "type": "object"
          }
        },
        "steps": {
          "type": "array",
          "description": "Ordered operation sequence for multi-step cases.",
          "items": { "$ref": "#/definitions/testStep" },
          "minItems": 1
        },
        "postconditions": {
          "type": "array",
          "description": "Binding targets to invoke after the case. Each must exit 0.",
          "items": {
            "type": "object",
            "required": ["target"],
            "properties": {
              "target": { "type": "string" },
              "inputs": { "type": "object" },
              "desc": { "type": "string" }
            }
          }
        }
      }
    },
    "testStep": {
      "type": "object",
      "required": ["operation"],
      "properties": {
        "operation": {
          "type": "string",
          "description": "Operation name."
        },
        "inputs": {
          "type": "object",
          "description": "Input values for this step."
        }
      }
    }
  }
}